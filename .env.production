# Production Environment Variables
# These are baked into the frontend bundle at build time by Vite.
# VITE_GRAPHQL_URL MUST point to the production API server — never localhost.
VITE_API_URL=https://api.hr.tradevu.co
VITE_GRAPHQL_URL=https://api.hr.tradevu.co/graphql
VITE_FEATURE_CHAT_MODULE=false
VITE_FEATURE_PERFORMANCE_MODULE=false
