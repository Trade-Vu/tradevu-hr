{
  "name": "Employee",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "Organization ID"
    },
    "full_name": {
      "type": "string",
      "description": "Employee full name"
    },
    "email": {
      "type": "string",
      "description": "Employee email"
    },
    "job_title": {
      "type": "string",
      "description": "Job title/position"
    },
    "department_id": {
      "type": "string",
      "description": "Department ID"
    },
    "template_id": {
      "type": "string",
      "description": "Onboarding template ID"
    },
    "start_date": {
      "type": "string",
      "format": "date",
      "description": "Expected start date"
    },
    "status": {
      "type": "string",
      "enum": [
        "not_started",
        "in_progress",
        "completed"
      ],
      "default": "not_started",
      "description": "Onboarding status"
    },
    "progress_percentage": {
      "type": "number",
      "default": 0,
      "description": "Overall completion percentage"
    },
    "phone": {
      "type": "string",
      "description": "Phone number"
    },
    "personal_info": {
      "type": "object",
      "description": "Additional personal information",
      "properties": {
        "address": {
          "type": "string"
        },
        "emergency_contact": {
          "type": "string"
        },
        "emergency_phone": {
          "type": "string"
        },
        "date_of_birth": {
          "type": "string",
          "format": "date"
        },
        "nationality": {
          "type": "string"
        },
        "national_id": {
          "type": "string"
        },
        "passport_number": {
          "type": "string"
        }
      }
    },
    "payroll_details": {
      "type": "object",
      "description": "Payroll and banking information",
      "properties": {
        "basic_salary": {
          "type": "number"
        },
        "bank_name": {
          "type": "string"
        },
        "account_number": {
          "type": "string"
        },
        "iban": {
          "type": "string"
        },
        "tax_number": {
          "type": "string"
        },
        "social_insurance_number": {
          "type": "string"
        },
        "allowances": {
          "type": "object",
          "properties": {
            "housing": {
              "type": "number"
            },
            "transport": {
              "type": "number"
            },
            "food": {
              "type": "number"
            },
            "other": {
              "type": "number"
            }
          }
        }
      }
    },
    "welcome_sent": {
      "type": "boolean",
      "default": false,
      "description": "Whether welcome email was sent"
    },
    "onboarding_completed_date": {
      "type": "string",
      "format": "date",
      "description": "Date onboarding was completed"
    }
  },
  "required": [
    "organization_id",
    "full_name",
    "email",
    "job_title",
    "start_date"
  ]
}