{
  "name": "Asset",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "Organization ID"
    },
    "asset_name": {
      "type": "string",
      "description": "Asset name (e.g., Macbook Air 2024)"
    },
    "asset_type": {
      "type": "string",
      "enum": [
        "laptop",
        "desktop",
        "phone",
        "tablet",
        "monitor",
        "keyboard",
        "mouse",
        "headset",
        "furniture",
        "vehicle",
        "other"
      ],
      "description": "Type of asset"
    },
    "serial_number": {
      "type": "string",
      "description": "Serial number or asset tag"
    },
    "purchase_date": {
      "type": "string",
      "format": "date",
      "description": "Purchase date"
    },
    "purchase_price": {
      "type": "number",
      "description": "Purchase price"
    },
    "assigned_to": {
      "type": "string",
      "description": "Employee email assigned to"
    },
    "assigned_to_name": {
      "type": "string",
      "description": "Employee name"
    },
    "assigned_date": {
      "type": "string",
      "format": "date",
      "description": "Date assigned to employee"
    },
    "return_date": {
      "type": "string",
      "format": "date",
      "description": "Expected/actual return date"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "in_repair",
        "broken",
        "retired"
      ],
      "default": "active",
      "description": "Asset status"
    },
    "assignment_status": {
      "type": "string",
      "enum": [
        "available",
        "assigned",
        "returned",
        "pending_return"
      ],
      "default": "available",
      "description": "Assignment status"
    },
    "condition": {
      "type": "string",
      "enum": [
        "excellent",
        "good",
        "fair",
        "poor",
        "broken"
      ],
      "default": "excellent",
      "description": "Asset condition"
    },
    "location": {
      "type": "string",
      "description": "Physical location"
    },
    "warranty_expiry": {
      "type": "string",
      "format": "date",
      "description": "Warranty expiration date"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes"
    }
  },
  "required": [
    "organization_id",
    "asset_name",
    "asset_type"
  ]
}