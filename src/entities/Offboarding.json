{
  "name": "Offboarding",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "Organization ID"
    },
    "employee_id": {
      "type": "string",
      "description": "Employee ID"
    },
    "employee_name": {
      "type": "string",
      "description": "Employee name"
    },
    "notice_date": {
      "type": "string",
      "format": "date",
      "description": "Notice date"
    },
    "last_working_day": {
      "type": "string",
      "format": "date",
      "description": "Last working day"
    },
    "termination_date": {
      "type": "string",
      "format": "date",
      "description": "Termination date"
    },
    "final_settlement": {
      "type": "number",
      "description": "Final settlement amount"
    },
    "checklist": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "task": {
            "type": "string"
          },
          "completed": {
            "type": "boolean"
          },
          "completed_date": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "description": "Offboarding checklist"
    },
    "status": {
      "type": "string",
      "enum": [
        "in_progress",
        "completed"
      ],
      "default": "in_progress",
      "description": "Offboarding status"
    },
    "completion_percentage": {
      "type": "number",
      "default": 0,
      "description": "Percentage of checklist completed"
    },
    "completed_date": {
      "type": "string",
      "format": "date",
      "description": "Date offboarding was completed"
    }
  },
  "required": [
    "organization_id",
    "employee_id",
    "notice_date",
    "last_working_day"
  ]
}