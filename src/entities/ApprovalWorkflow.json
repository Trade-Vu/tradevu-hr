{
  "name": "ApprovalWorkflow",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "Organization ID"
    },
    "workflow_name": {
      "type": "string",
      "description": "Workflow name"
    },
    "workflow_type": {
      "type": "string",
      "enum": [
        "leave",
        "expense",
        "loan",
        "payroll",
        "recruitment",
        "other"
      ],
      "description": "Type of workflow"
    },
    "approval_levels": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "level": {
            "type": "number"
          },
          "approver_role": {
            "type": "string"
          },
          "approver_emails": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "is_mandatory": {
            "type": "boolean"
          },
          "auto_approve_threshold": {
            "type": "number"
          }
        }
      },
      "description": "Approval levels hierarchy"
    },
    "use_hierarchy": {
      "type": "boolean",
      "default": true,
      "description": "Use org chart hierarchy for approvals"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Whether workflow is active"
    }
  },
  "required": [
    "organization_id",
    "workflow_name",
    "workflow_type"
  ]
}