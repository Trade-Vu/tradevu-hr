{
  "name": "OvertimeRecord",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "Organization ID"
    },
    "employee_id": {
      "type": "string",
      "description": "Employee ID"
    },
    "employee_name": {
      "type": "string",
      "description": "Employee name"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Overtime date"
    },
    "hours": {
      "type": "number",
      "description": "Overtime hours worked"
    },
    "rate_per_hour": {
      "type": "number",
      "description": "Overtime rate per hour (SAR)"
    },
    "total_amount": {
      "type": "number",
      "description": "Total overtime compensation"
    },
    "compensation_type": {
      "type": "string",
      "enum": [
        "cash",
        "time_off"
      ],
      "default": "cash",
      "description": "How overtime is compensated"
    },
    "is_ramadan": {
      "type": "boolean",
      "default": false,
      "description": "Whether during Ramadan (reduced hours)"
    },
    "approved_by": {
      "type": "string",
      "description": "Manager who approved"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "paid"
      ],
      "default": "pending",
      "description": "Overtime status"
    }
  },
  "required": [
    "organization_id",
    "employee_id",
    "date",
    "hours"
  ]
}