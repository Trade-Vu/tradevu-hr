{
  "name": "Applicant",
  "type": "object",
  "properties": {
    "job_posting_id": {
      "type": "string",
      "description": "Job posting ID"
    },
    "full_name": {
      "type": "string",
      "description": "Applicant full name"
    },
    "email": {
      "type": "string",
      "description": "Email address"
    },
    "phone": {
      "type": "string",
      "description": "Phone number"
    },
    "cv_url": {
      "type": "string",
      "description": "CV/Resume file URL"
    },
    "cover_letter": {
      "type": "string",
      "description": "Cover letter"
    },
    "experience_years": {
      "type": "number",
      "description": "Years of experience"
    },
    "current_salary": {
      "type": "number",
      "description": "Current salary"
    },
    "expected_salary": {
      "type": "number",
      "description": "Expected salary"
    },
    "status": {
      "type": "string",
      "enum": [
        "new",
        "reviewed",
        "shortlisted",
        "interview_scheduled",
        "interviewed",
        "offered",
        "hired",
        "rejected"
      ],
      "default": "new",
      "description": "Application status"
    },
    "ai_score": {
      "type": "number",
      "description": "AI relevance score (0-100)"
    },
    "ai_summary": {
      "type": "string",
      "description": "AI-generated candidate summary"
    },
    "interview_date": {
      "type": "string",
      "format": "date-time",
      "description": "Scheduled interview date"
    },
    "interview_notes": {
      "type": "string",
      "description": "Interview feedback"
    },
    "source": {
      "type": "string",
      "enum": [
        "direct",
        "bayt",
        "linkedin",
        "facebook",
        "referral"
      ],
      "description": "Application source"
    },
    "application_date": {
      "type": "string",
      "format": "date",
      "description": "Date applied"
    }
  },
  "required": [
    "job_posting_id",
    "full_name",
    "email",
    "phone"
  ]
}