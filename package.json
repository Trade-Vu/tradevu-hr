{
  "name": "base44-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp dist/index.html dist/404.html",
    "build:staging": "vite build --mode staging && cp dist/index.html dist/404.html",
    "lint": "eslint .",
    "typecheck": "tsc -p ./jsconfig.json",
    "preview": "vite preview",
    "start": "vite preview --host 0.0.0.0 --port $PORT || 4173",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:auth": "cypress run --spec 'cypress/e2e/auth.cy.js'",
    "cypress:run:dashboard": "cypress run --spec 'cypress/e2e/dashboard.cy.js'",
    "cypress:run:employees": "cypress run --spec 'cypress/e2e/employees.cy.js'",
    "cypress:run:api": "cypress run --spec 'cypress/e2e/api-integration.cy.js'",
    "cypress:run:onboarding": "cypress run --spec 'cypress/e2e/onboarding-flow.cy.js'",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "start-server-and-test dev http://localhost:5173 cypress:run",
    "test:e2e:onboarding": "start-server-and-test dev http://localhost:5173 cypress:run:onboarding"
  },
  "dependencies": {
